# Pairly production env. Copy to .env.prod (gitignored) and fill in.
# All vars use the PAIRLY_ prefix (see backend/pairly/config.py).

# ---------- Required ----------
# Telegram bot token from @BotFather.
PAIRLY_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Public domain that points to the VPS via DNS A record.
# Used by Caddy for Let's Encrypt auto-issue.
PAIRLY_PUBLIC_DOMAIN=your-domain.example.com

# ---------- Recommended defaults ----------
# SQLite is fine for one or a few pairs. Switch to Postgres for prod scale.
# Postgres example: postgresql+asyncpg://pairly:SECRET@db:5432/pairly
PAIRLY_DATABASE_URL=sqlite+aiosqlite:////data/pairly.db

# Bot webhook mode (prod). Caddy terminates TLS and forwards
# https://PAIRLY_PUBLIC_DOMAIN/telegram-webhook to bot:8080.
PAIRLY_BOT_POLLING=false
PAIRLY_WEBHOOK_URL=https://your-domain.example.com
PAIRLY_WEBHOOK_PATH=/telegram-webhook
PAIRLY_WEBHOOK_PORT=8080
PAIRLY_WEBHOOK_HOST=0.0.0.0
# Webhook secret token (X-Telegram-Bot-Api-Secret-Token). MUST be stable across
# bot restarts — Telegram will drop every update if the secret rotates. Generate
# once with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# and paste the value here. Leave empty in dev (polling mode ignores this).
PAIRLY_WEBHOOK_SECRET_TOKEN=

# Public URL of the Mini App. MUST equal PAIRLY_PUBLIC_DOMAIN (or a subdomain
# on the same zone). Must be registered with @BotFather -> /setdomain BEFORE
# the bot will let users open it from a button.
PAIRLY_WEBAPP_URL=https://your-domain.example.com

# API.
PAIRLY_API_HOST=0.0.0.0
PAIRLY_API_PORT=8000

# Auth: MUST be false in production (real HMAC validation).
PAIRLY_DEV_AUTH=false

# Free-tier limits (per pair; Pro = unlimited).
PAIRLY_FREE_WISHLIST_LIMIT=10
PAIRLY_FREE_COUNTDOWN_LIMIT=10
PAIRLY_FREE_BUCKET_LIMIT=5

# Logging.
PAIRLY_DEBUG=false

# Admin gating: comma-separated Telegram user ids that may use /admin.
# Find yours: message @userinfobot on Telegram. Empty = no one (safe default).
PAIRLY_ADMIN_TG_IDS=

# ---------- Optional (for backup.sh if you run it on the host too) ----------
# PAIRLY_BACKUP_BUCKET=s3://your-bucket/pairly
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_ENDPOINT_URL_S3=https://s3.amazonaws.com   # or your S3-compatible host
