# Mini App build-time config.
#
# In production: VITE_USE_MOCK=false and VITE_API_URL empty (uses relative paths
# — the Mini App calls /api/* on the same host where Caddy reverse-proxies to
# the FastAPI container).
#
# In local dev with mock data: VITE_USE_MOCK=true and VITE_API_URL empty or
# http://localhost:8000 (the mock doesn't actually network, but `new URL(path)`
# needs a valid base).
#
# Inside an actual Telegram client (no mock): VITE_USE_MOCK=false and
# VITE_API_URL empty; the client sends `X-Telegram-Init-Data` automatically.

VITE_API_URL=
VITE_USE_MOCK=false

# Only used for plain-browser dev when VITE_USE_MOCK=false (you'd need a backend
# running with PAIRLY_DEV_AUTH=1 and PAIRLY_BOT_TOKEN set, and you pass the
# internal User UUID here as a stand-in for initData).
# VITE_DEV_USER_ID=
