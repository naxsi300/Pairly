# Pairly backend environment.
# Copy to `.env` and fill in. All vars use the PAIRLY_ prefix.

# Telegram bot token from @BotFather (required).
PAIRLY_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Database URL. SQLite for dev (default), Postgres for prod.
PAIRLY_DATABASE_URL=sqlite+aiosqlite:///./pairly.db
# Prod example:
# PAIRLY_DATABASE_URL=postgresql+asyncpg://pairly:secret@localhost:5432/pairly

# FastAPI Mini App API.
PAIRLY_API_HOST=127.0.0.1
PAIRLY_API_PORT=8000

# Free-tier limits (per pair). Pro = unlimited.
PAIRLY_FREE_WISHLIST_LIMIT=10
PAIRLY_FREE_COUNTDOWN_LIMIT=10
PAIRLY_FREE_BUCKET_LIMIT=5

# Bot run mode.
PAIRLY_BOT_POLLING=true
PAIRLY_DEBUG=false

# Admin gating: comma-separated Telegram user ids that may use /admin. Empty = disabled.
PAIRLY_ADMIN_TG_IDS=
