# Pairly e2e environment.
# Copy to `.env` (loaded by @playwright/test automatically). All optional.

# Mini App dev server URL. `make e2e` boots `vite` on this port with mock mode on.
E2E_MINIAPP_URL=http://localhost:5173

# FastAPI Mini App API URL, used by the real-API / health scenarios.
# `make e2e` boots `uvicorn` (or you run it separately via `make api`).
E2E_API_URL=http://localhost:8000

# Comma-separated project names to run (default: chromium). See playwright.config.ts.
# E2E_PROJECTS=chromium
