# Pairly Caddyfile — auto-HTTPS, reverse-proxy /api/*, serve the Mini App.
#
# Install: /etc/caddy/Caddyfile  (replace the existing one, then `systemctl reload caddy`).
#
# TODO(operator): replace `app.example.com` with your real domain. DNS for that
# domain must point at this VPS so Caddy can obtain/renew the Let's Encrypt cert.
#
# Layout assumed:
#   /var/www/pairly        -> built Mini App (miniapp/dist), owned readable by caddy
#   127.0.0.1:8000         -> pairly-api.service (uvicorn)

# Global options: ACME email for Let's Encrypt registration/renewal.
# TODO(operator): change to a real mailbox you monitor; Caddy uses it for
# expiry warnings and account recovery.
{
    email ops@pairly.mnepo.fyi
}

app.example.com {
	encode zstd gzip

	# Hard cap on request bodies at the edge. The app-side limiter from cluster 5
	# is the primary defense; this stops oversized payloads from reaching the
	# upstream (1 MiB is well above our largest legit payload, a <512 KiB photo).
	request_body {
		max_size 1MB
	}

	# API: FastAPI on uvicorn. Strip /api prefix? No — the app is mounted at /api/*.
	# Keep the path so the router matches. Proxy headers so the app sees real client info.
	handle_path /api/* {
		reverse_proxy 127.0.0.1:8000 {
			# Strip client-supplied dev-impersonation headers at the edge.
			# If an external caller spoofs `X-Dev-User-Id`, the app would
			# happily impersonate any user. We MUST NOT trust it from the
			# wire. The legit Mini App client sends `X-Telegram-Init-Data`
			# instead — that one stays.
			header_up -X-Dev-User-Id
		}
	}

	# Also expose the bare /api (without trailing path) to the upstream root router.
	handle /api {
		reverse_proxy 127.0.0.1:8000 {
			header_up -X-Dev-User-Id
		}
	}

	# Static Mini App (PWA shell). SPA fallback so client routes resolve to index.html.
	root * /var/www/pairly
	try_files {path} /index.html
	file_server

	# Cache hashed /assets/* forever (filename includes content hash);
	# never cache /index.html so the SW autoUpdate hot-fix path works.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Entry HTML, service worker, and manifest must always revalidate.
	# Telegram's WebView heuristically caches URLs that lack an explicit
	# Cache-Control — '/' (the URL TG actually opens) and '/sw.js' went stale
	# across deploys. The old rule matched only '/index.html', which nobody
	# requests directly. Hashed /assets/* stay immutable above.
	@nocache path / /index.html /sw.js /manifest.webmanifest
	header @nocache Cache-Control "no-cache, must-revalidate"

	# Reasonable security headers; Mini App is a PWA served to Telegram clients.
	header {
		# HSTS: 1 year, include subdomains. Deliberately NO `preload` —
		# submission to the browser preload list is irreversible without
		# shipping an HTTP response with `preload` removed, which is easy
		# to miss. Leave it off until the operator confirms intent.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# CSP: allow Telegram WebApp scripts + self. 'unsafe-inline' was
		# removed from script-src after a sweep of miniapp/index.html and
		# miniapp/src found NO inline scripts, dangerouslySetInnerHTML, or
		# eval(). Tighten further after audit.
		#
		# frame-ancestors covers the known Telegram web origins that
		# actually embed the Mini App (kept in sync with Caddyfile.docker,
		# which is the source of truth for the prod-docker deploy):
		#   https://web.telegram.org       — Telegram Web A (canonical)
		#   https://k.web.telegram.org     — Telegram Web K
		#   https://telegram.org           — shared Telegram web origin
		# The native iOS/Android Telegram client opens Mini Apps WITHOUT
		# sending an `Origin` header, so the browser-side check is vacuous
		# for that path; CSRF defense is enforced server-side via
		# `X-Telegram-Init-Data` validation, not via CSP. `frame-ancestors
		# 'none'` would block ALL Telegram embeds (and is the only value
		# we are NOT allowed to ship here), so we enumerate the real
		# origins instead.
		Content-Security-Policy "default-src 'self'; script-src 'self' https://telegram.org; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://telegram.org; frame-ancestors https://web.telegram.org https://k.web.telegram.org https://telegram.org"
	}

	# Health endpoint for uptime monitors (over HTTPS).
	handle /health {
		respond "ok" 200
	}

	# Access log with PII redaction.
	#
	# `/api/wishlist/*/photo` accepts `init_data` + `dev_user_id` as query
	# params (the former because `<img src="...">` can't set custom
	# headers; the latter because dev_auth is gated only by the header
	# being absent). Caddy's default `console` format records the full
	# request URI, which means the captured 24h-replayable Telegram
	# initData AND the dev impersonation id would land in
	# /var/log/caddy/*.log readable by caddy. We use the `filter` log
	# format with `request>uri query { replace ... REDACTED }` so the
	# keys are replaced with a placeholder before the line is written.
	log {
		output file /var/log/caddy/pairly-access.log {
			roll_size 10mb
			roll_keep 5
		}
		format filter {
			request>uri query {
				replace init_data REDACTED
				replace dev_user_id REDACTED
			}
		}
	}
}

# TODO(cluster-8d, rate_limit): Caddy's `rate_limit` directive is a plugin
# (mholt/caddy-ratelimit), not in stock caddy:2-alpine or Debian's
# apt-caddy. To enable, build a custom image with `xcaddy build` and
# include github.com/mholt/caddy-ratelimit, then add a coarse per-IP
# limit scoped to /api/* (e.g. zone "api" { key {remote_host} window 1m
# events 600 }). Until then, the app-side limiter from cluster 5 is the
# primary defense.