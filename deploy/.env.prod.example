# Pairly deploy env example. Copy to /etc/pairly/pairly.env on the VPS
# (chmod 600, owner pairly:pairly). Loaded by systemd units, cron, and
# the deploy/*.sh scripts.
#
# This file documents the vars that deploy scripts and systemd units
# consume. Runtime/app config (bot token, app urls, free-tier caps, etc.)
# lives in the project root `.env.prod.example` — that file is the
# source of truth for the python app. THIS file is for the OPERATOR's
# /etc/pairly/pairly.env skeleton.

# ---------- Telegram webhook (must match root .env.prod.example) ----------
# Webhook secret token (X-Telegram-Bot-Api-Secret-Token). MUST be stable
# across bot restarts — Telegram will drop every update if the secret
# rotates. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# and paste the value here. Used by Caddy (Authorization header) and the
# aiogram dispatcher (X-Telegram-Bot-Api-Secret-Token check). Leave empty
# in dev (polling mode ignores this).
PAIRLY_WEBHOOK_SECRET_TOKEN=

# ---------- Database ----------
# Same string the app reads; we duplicate it here so the deploy scripts
# can `set -o allexport; . /etc/pairly/pairly.env` without the app env.
# SQLite (single VPS) or Postgres (managed / separate db host).
PAIRLY_DATABASE_URL=sqlite+aiosqlite:////var/lib/pairly/pairly.db

# ---------- S3 / backup ----------
# bucket + key prefix
PAIRLY_BACKUP_BUCKET=pairly-backups
PAIRLY_BACKUP_PREFIX=pairly
# local staging dir (intermediate dump file before s3 cp)
PAIRLY_LOCAL_DIR=/var/backups/pairly
# log file (cron mail fails are caught here)
LOG_FILE=/var/log/pairly/backup.log

# AWS / S3-compatible creds.
AWS_ACCESS_KEY_ID=CHANGEME
AWS_SECRET_ACCESS_KEY=CHANGEME
# Non-AWS providers (Selectel / YC / etc.) need an explicit endpoint.
# AWS leave empty.
AWS_ENDPOINT_URL_S3=
AWS_REGION=ru-1

# Server-side encryption for the dump object on S3.
#   AES256         -> SSE-S3 (default if unset). Cheapest, no extra setup.
#   aws:kms        -> SSE-KMS. Requires PAIRLY_BACKUP_KMS_KEY_ID below
#                     to be set to a valid KMS key ARN / alias / id.
PAIRLY_BACKUP_SSE=AES256

# Only used when PAIRLY_BACKUP_SSE=aws:kms. Leave empty (default AWS
# managed key for the bucket) OR set to a specific key ARN:
#   arn:aws:kms:ru-1:123456789012:key/abcd-...
PAIRLY_BACKUP_KMS_KEY_ID=
